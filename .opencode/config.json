      "mode": "subagent",
      "prompt": "{file:.opencode/agents/node-backend-developer.md}",
      "color": "#10b981",
      "permission": {
        "edit": "allow",
        "webfetch": "allow",
        "skill": { "*": "allow" },
        "bash": {
          "*": "ask",
          "npm *": "allow",
          "pnpm *": "allow",
          "bun *": "allow",
