    "android": {
      "description": "Expert Android developer for Kotlin, Jetpack Compose, XML, Material Design 3, and Google Play (subagent of IT Leader)",
      "mode": "subagent",
      "prompt": "{file:.opencode/agents/android-developer.md}",
      "color": "#22c55e",
