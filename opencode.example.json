{
  "$schema": "https://opencode.ai/config.json",
  "description": "IT Team Agent Configuration Example — Copy ke opencode.json dan sesuaikan model sesuai kebutuhan",
  "note": "Opsional: Jika tidak set model per agent, subagent akan inherit dari primary (IT Leader). Untuk customize, uncomment model line per agent.",
  "formatter": true,
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "question": "allow",
    "doom_loop": "ask",
    "external_directory": {
      "*": "allow",
      "~/.ssh/**": "deny",
      "~/.aws/**": "deny",
      "~/.config/**": "deny",
      "~/secrets/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "/etc/**": "deny"
    },
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "type *": "allow",
      "mkdir *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "date": "allow",
      "uname *": "allow",
      "whoami": "allow",
      "file *": "allow",
      "wc *": "allow",
      "du *": "allow",
      "df *": "allow"
    },
    "agentmemory_*": "allow",
    "figma_*": "allow"
  },
  "instructions": [
    ".opencode/instructions/INSTRUCTIONS.md",
    ".opencode/skills/coding-standards/SKILL.md",
    ".opencode/skills/security-review/SKILL.md",
    ".opencode/skills/impeccable/SKILL.md",
    ".opencode/skills/it-leader-orchestration/SKILL.md",
    ".opencode/skills/eval-harness/SKILL.md",
    ".opencode/skills/verification-loop/SKILL.md",
    ".opencode/skills/strategic-compact/SKILL.md",
    ".opencode/skills/api-design/SKILL.md",
    ".opencode/skills/agent-task-workflow/SKILL.md",
    ".opencode/skills/agent-communication/SKILL.md",
    ".opencode/skills/agent-session-workflow/SKILL.md"
  ],
  "mcp": {
    "nuxt": {
      "type": "remote",
      "url": "https://nuxt.com/mcp",
      "enabled": true,
      "description": "Nuxt documentation, blog posts, and deployment guides"
    },
    "nuxt-ui": {
      "type": "remote",
      "url": "https://ui.nuxt.com/mcp",
      "enabled": true,
      "description": "Nuxt UI component documentation and examples"
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp"
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-playwright"],
      "enabled": true,
      "description": "Browser automation and E2E testing with Playwright"
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "${STITCH_API_KEY}"
      },
      "description": "Google Stitch AI design generation (requires STITCH_API_KEY)"
    },
    "postman": {
      "type": "remote",
      "url": "https://mcp.postman.com/mcp",
      "headers": {
        "Authorization": "Bearer ${POSTMAN_API_KEY}"
      },
      "enabled": true,
      "description": "Postman API management for collections, requests, and documentation"
    },
    "sonarqube": {
      "type": "remote",
      "url": "https://sonarqube-mcp.sadigit.co.id/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer ${SONARQUBE_TOKEN}",
        "SONARQUBE_TOOLSETS": "analysis,issues,security-hotspots,quality-gates,rules,duplications,measures,dependency-risks,coverage,sources,languages,portfolios,system,webhooks"
      }
    },
    "agentmemory": {
      "type": "local",
      "command": ["bash", ".opencode/hooks/agentmemory-start.sh"],
      "enabled": true,
      "description": "Persistent cross-session memory with 53 tools (save, recall, smart search, sessions, file history, lessons)"
    }
  },
  "plugin": [".opencode/plugins/agentmemory-capture.ts", ".opencode/plugins/ponytail.mjs"],
  "agent": {
    "leader": {
      "description": "IT Leader & Technical Project Manager — analyzes requirements, designs architecture, decomposes tasks, delegates to subagents, and unifies outputs",
      "mode": "primary",
      "prompt": "{file:.opencode/agents/it-leader.md}",
      "model": "opencode/claude-opus-4.7",
      "temperature": 0.4,
      "color": "#8b5cf6",
